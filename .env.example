# ─── eBay API (required for search) ──────────────────────────────────────────
# Get free keys at https://developer.ebay.com
EBAY_APP_ID=your-app-id-here
EBAY_CERT_ID=your-cert-id-here

# ─── Notifications (all optional) ────────────────────────────────────────────

# Discord webhook (Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=

# Telegram bot (create with @BotFather, get chat_id from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email / SMS-via-email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
